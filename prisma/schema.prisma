generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Internal staffing ONLY — never store commercial customers here.
model User {
  id             Int               @id @default(autoincrement())
  email          String            @unique
  password       String
  role           String            @default("EMPLOYEE")
  employeeName   String
  activeStatus   Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignedJobs   JobMetadata[]
  createdJobs    JobMetadata[]     @relation("CreatedJobs")
  createdSurveys SurveyReport[]    @relation("CreatedSurveys")
  createdQuotations QuotationInvoice[] @relation("CreatedQuotations")
  createdExpenses Expense[]       @relation("CreatedExpenses")
  createdPayments PaymentReceived[] @relation("CreatedPayments")
  createdWorkCompletions WorkCompletion[] @relation("CreatedWorkCompletions")
  gmailAccounts  GmailAccount[]
  createdTickets Ticket[]        @relation("CreatedTickets")
}

/// Gmail OAuth connection and sync tracking.
model GmailAccount {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailEmail     String    @unique
  accessToken    String
  refreshToken   String
  expiryDate     BigInt
  syncedAt       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  syncedEmailIds String    @default("[]")
  tickets        Ticket[]
}

/// Automated Gmail ingestion stream.
model Ticket {
  id             Int          @id @default(autoincrement())
  gmailAccountId Int?
  gmailAccount   GmailAccount? @relation(fields: [gmailAccountId], references: [id], onDelete: SetNull)
  gmailMessageId String       @unique
  serialNo       String       @unique
  exactDate      DateTime
  time           String
  subject        String
  sender         String
  createdAt      DateTime     @default(now())
  jobMetadata    JobMetadata?
  createdById    Int?
  createdBy      User?        @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: SetNull)
}

/// Commercial customers and site branches live here — NOT in User.
model JobMetadata {
  id                 Int                @id @default(autoincrement())
  ticketId           Int                @unique
  ticket             Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  clientName         String
  branchName         String
  personOfContact    String
  workNature         String
  assignedEmployeeId Int?
  assignedEmployee   User?              @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  manualEnteredBy    String?
  createdById        Int?
  createdBy          User?        @relation("CreatedJobs", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  paymentProgress    Int?           @default(0)
  surveyReport       SurveyReport?
  quotationInvoices  QuotationInvoice[]
  expenses           Expense[]
  payments           PaymentReceived[]
  workCompletion     WorkCompletion?
}

model SurveyReport {
  id            Int         @id @default(autoincrement())
  jobMetadataId Int         @unique
  jobMetadata   JobMetadata @relation(fields: [jobMetadataId], references: [id], onDelete: Cascade)
  createdById   Int?
  createdBy     User?       @relation("CreatedSurveys", fields: [createdById], references: [id], onDelete: SetNull)
  reportText    String
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model QuotationInvoice {
  id            Int             @id @default(autoincrement())
  jobMetadataId Int
  jobMetadata   JobMetadata     @relation(fields: [jobMetadataId], references: [id], onDelete: Cascade)
  createdById   Int?
  createdBy     User?           @relation("CreatedQuotations", fields: [createdById], references: [id], onDelete: SetNull)
  poNumber      String?
  status        String          @default("PENDING")
  documentType  String          @default("QUOTATION")
  lineItems     String          @default("[]")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime    @updatedAt
}

model Expense {
  id            Int         @id @default(autoincrement())
  jobMetadataId Int
  jobMetadata   JobMetadata @relation(fields: [jobMetadataId], references: [id], onDelete: Cascade)
  createdById   Int?
  createdBy     User?       @relation("CreatedExpenses", fields: [createdById], references: [id], onDelete: SetNull)
  amount        Float
  imageUrl      String?
  summaryNotes  String
  createdAt     DateTime    @default(now())
}

model PaymentReceived {
  id            Int         @id @default(autoincrement())
  jobMetadataId Int
  jobMetadata   JobMetadata @relation(fields: [jobMetadataId], references: [id], onDelete: Cascade)
  createdById   Int?
  createdBy     User?       @relation("CreatedPayments", fields: [createdById], references: [id], onDelete: SetNull)
  amount        Float
  taxDeducted   Float       @default(0)
  imageUrl      String?
  summaryNotes  String
  createdAt     DateTime    @default(now())
}

model WorkCompletion {
  id            Int         @id @default(autoincrement())
  jobMetadataId Int         @unique
  jobMetadata   JobMetadata @relation(fields: [jobMetadataId], references: [id], onDelete: Cascade)
  createdById   Int?
  createdBy     User?       @relation("CreatedWorkCompletions", fields: [createdById], references: [id], onDelete: SetNull)
  status        String      @default("PENDING")
  amount        Float       @default(0)
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
